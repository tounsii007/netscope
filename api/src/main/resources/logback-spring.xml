<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

  <!-- ══════════════════════════════════════════════════════════════════
       NetScope — Logback configuration
       Daily rolling: every file gets a date suffix (e.g. server.2025-01-15.log).
       At midnight the current file is closed and a new dated file is opened.
       Old files are GZip-compressed and kept according to maxHistory.

       Log directory: resolved from $LOG_PATH env var (default: logs/)
       ══════════════════════════════════════════════════════════════════ -->

  <springProperty name="LOG_PATH"  source="logging.file.path"  defaultValue="logs"/>
  <springProperty name="APP_NAME"  source="spring.application.name" defaultValue="netscope"/>
  <springProperty name="LOG_LEVEL" source="logging.level.root"  defaultValue="INFO"/>

  <!-- ─── Patterns ──────────────────────────────────────────────────── -->
  <property name="CONSOLE_PATTERN"
            value="%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{40}) %msg%n%ex{5}"/>
  <property name="FILE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n%ex{full}"/>
  <property name="ACCESS_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n"/>

  <!-- ═══════════════════════════════════════════════════════════════════
       CONSOLE  (coloured — active in all profiles)
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${CONSOLE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       server.YYYY-MM-DD.log
       All INFO+ events from every package.
       Retention: 30 days / max 2 GB total.
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="SERVER_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <!-- Date is part of the active file name — no symlink needed -->
      <fileNamePattern>${LOG_PATH}/server.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>2GB</totalSizeCap>
      <cleanHistoryOnStart>false</cleanHistoryOnStart>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>INFO</level>
    </filter>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       error.YYYY-MM-DD.log
       ERROR-level only — with full stack trace.
       Retention: 90 days / max 500 MB.
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>90</maxHistory>
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <!-- Strictly ERROR — nothing else goes in here -->
    <filter class="ch.qos.logback.classic.filter.LevelFilter">
      <level>ERROR</level>
      <onMatch>ACCEPT</onMatch>
      <onMismatch>DENY</onMismatch>
    </filter>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       security.YYYY-MM-DD.log
       Auth, API key, rate-limit, SSRF and privilege events.
       Retention: 365 days (legal/compliance requirement).
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/security.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>365</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       webhook.YYYY-MM-DD.log
       Outbound webhook delivery attempts, retries, dead-letter events.
       Retention: 30 days / max 500 MB.
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="WEBHOOK_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/webhook.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       scheduler.YYYY-MM-DD.log
       CT-log monitor + uptime scheduler events.
       Retention: 14 days.
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="SCHEDULER_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/scheduler.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>14</maxHistory>
      <totalSizeCap>200MB</totalSizeCap>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       billing.YYYY-MM-DD.log
       Stripe events, subscription changes, usage metering.
       Retention: 365 days (financial compliance).
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="BILLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/billing.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>365</maxHistory>
      <totalSizeCap>200MB</totalSizeCap>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       access.YYYY-MM-DD.log
       Every inbound HTTP request: method, path, status, latency.
       Written by AccessLogFilter (see below) at TRACE level on a
       dedicated logger "ACCESS".
       Retention: 30 days / max 2 GB.
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="ACCESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/access.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>2GB</totalSizeCap>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <!-- Compact single-line access log — no duplicate date in message -->
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       Async wrappers — decouple I/O from request threads
       ═══════════════════════════════════════════════════════════════════ -->
  <appender name="ASYNC_SERVER" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="SERVER_FILE"/>
    <queueSize>1024</queueSize>
    <discardingThreshold>0</discardingThreshold>
    <includeCallerData>false</includeCallerData>
    <neverBlock>false</neverBlock>
  </appender>

  <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="ERROR_FILE"/>
    <queueSize>256</queueSize>
    <discardingThreshold>0</discardingThreshold>
  </appender>

  <appender name="ASYNC_ACCESS" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="ACCESS_FILE"/>
    <queueSize>2048</queueSize>
    <discardingThreshold>0</discardingThreshold>
  </appender>

  <!-- ═══════════════════════════════════════════════════════════════════
       Package-level loggers — route specific packages to dedicated files
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Security: auth, API key validation, rate-limiter, SSRF guard -->
  <logger name="io.netscope.auth"   level="DEBUG" additivity="false">
    <appender-ref ref="SECURITY_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
    <appender-ref ref="CONSOLE"/>
  </logger>
  <logger name="io.netscope.user"   level="DEBUG" additivity="false">
    <appender-ref ref="SECURITY_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
    <appender-ref ref="CONSOLE"/>
  </logger>
  <logger name="io.netscope.audit"  level="DEBUG" additivity="false">
    <appender-ref ref="SECURITY_FILE"/>
    <appender-ref ref="ASYNC_ERROR"/>
    <appender-ref ref="CONSOLE"/>
  </logger>
  <logger name="io.netscope.common.RateLimitFilter" level="WARN" additivity="false">
    <appender-ref ref="SECURITY_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
  </logger>
  <logger name="io.netscope.common.TargetValidator" level="WARN" additivity="false">
    <appender-ref ref="SECURITY_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
  </logger>

  <!-- Webhook deliveries -->
  <logger name="io.netscope.webhook" level="DEBUG" additivity="false">
    <appender-ref ref="WEBHOOK_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
    <appender-ref ref="ASYNC_ERROR"/>
    <appender-ref ref="CONSOLE"/>
  </logger>

  <!-- Schedulers (CT monitor + uptime) -->
  <logger name="io.netscope.ctmonitor" level="INFO" additivity="false">
    <appender-ref ref="SCHEDULER_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
    <appender-ref ref="ASYNC_ERROR"/>
    <appender-ref ref="CONSOLE"/>
  </logger>
  <logger name="io.netscope.monitor" level="INFO" additivity="false">
    <appender-ref ref="SCHEDULER_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
    <appender-ref ref="ASYNC_ERROR"/>
    <appender-ref ref="CONSOLE"/>
  </logger>

  <!-- Billing / Stripe -->
  <logger name="io.netscope.billing" level="INFO" additivity="false">
    <appender-ref ref="BILLING_FILE"/>
    <appender-ref ref="ASYNC_SERVER"/>
    <appender-ref ref="ASYNC_ERROR"/>
    <appender-ref ref="CONSOLE"/>
  </logger>

  <!-- HTTP access log (written by AccessLogFilter) -->
  <logger name="ACCESS" level="TRACE" additivity="false">
    <appender-ref ref="ASYNC_ACCESS"/>
  </logger>

  <!-- Suppress noisy framework internals -->
  <logger name="org.hibernate.SQL"                         level="WARN"/>
  <logger name="org.hibernate.type.descriptor.sql"         level="WARN"/>
  <logger name="org.springframework.web.servlet"           level="WARN"/>
  <logger name="org.springframework.security"              level="WARN"/>
  <logger name="com.zaxxer.hikari"                         level="INFO"/>
  <logger name="io.lettuce"                                level="WARN"/>
  <logger name="org.springframework.data.redis"            level="WARN"/>

  <!-- ═══════════════════════════════════════════════════════════════════
       Root logger — catches everything not matched above
       ═══════════════════════════════════════════════════════════════════ -->
  <root level="${LOG_LEVEL}">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="ASYNC_SERVER"/>
    <appender-ref ref="ASYNC_ERROR"/>
  </root>

</configuration>
