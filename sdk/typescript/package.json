{
  "name": "@netscope/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the NetScope network diagnostics API",
  "keywords": ["netscope", "dns", "ssl", "port", "monitor", "ip", "whois"],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.7.3",
    "vitest": "4.1.0"
  },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/netscope/netscope" }
}
