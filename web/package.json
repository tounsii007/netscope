{
  "name": "traceronix-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:load:smoke":    "k6 run tests/load/01-smoke.js",
    "test:load:standard": "k6 run tests/load/02-load.js",
    "test:load:stress":   "k6 run tests/load/03-stress-1000.js",
    "test:load:same":     "k6 run tests/load/04-stress-1000-same.js",
    "test:load:spike":    "k6 run tests/load/05-spike-5000.js",
    "test:load:soak":     "k6 run tests/load/06-soak-10000.js",
    "test:load:docker:smoke":    "docker run --rm -i -v \"%cd%:/app\" -w /app grafana/k6 run tests/load/01-smoke.js",
    "test:load:docker:standard": "docker run --rm -i -v \"%cd%:/app\" -w /app grafana/k6 run tests/load/02-load.js",
    "test:load:docker:stress":   "docker run --rm -i -v \"%cd%:/app\" -w /app grafana/k6 run tests/load/03-stress-1000.js",
    "test:load:docker:spike":    "docker run --rm -i -v \"%cd%:/app\" -w /app grafana/k6 run tests/load/05-spike-5000.js",
    "perf:budget": "node tests/perf/check-bundle-budget.mjs"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "leaflet": "1.9.4",
    "lucide-react": "0.577.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.11.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "2.6.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/leaflet": "1.9.21",
    "@types/node": "^22.19.18",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.1.4",
    "jsdom": "29.1.1",
    "msw": "2.7.0",
    "postcss": "8.5.14",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vitest": "3.2.4"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
