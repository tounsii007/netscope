NEXT_PUBLIC_API_URL=http://localhost:8080

# F-FE-05: NextAuth canonical base URL. REQUIRED in production.
#
# We pin trustHost=false in auth.ts so NextAuth refuses to derive the base
# URL from X-Forwarded-Host / X-Forwarded-Proto (which any peer can
# forge). Set this to the externally-visible https origin of the web app
# instead — e.g. https://app.netscope.example.com — with no trailing
# slash. In local dev http://localhost:3000 is fine.
NEXTAUTH_URL=http://localhost:3000

# NextAuth JWT signing secret. REQUIRED. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-random-32-byte-base64-string
